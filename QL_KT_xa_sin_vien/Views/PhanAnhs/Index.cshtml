@model IEnumerable<QL_KT_xa_sin_vien.Models.PhanAnh>

@{
    ViewData["Title"] = "Danh sách phản ánh";
}

<h2 class="mb-4">Danh sách phản ánh</h2>

<p>
    <a asp-action="Create" class="btn btn-success mb-3">+ Thêm phản ánh mới</a>
</p>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Người gửi</th>
                    <th>@Html.DisplayNameFor(model => model.MoTa)</th>
                    <th>@Html.DisplayNameFor(model => model.MucDoUuTien)</th>
                    <th>Đính kèm</th>
                    <th>Trạng thái</th>
                    <th>@Html.DisplayNameFor(model => model.ThoiGianTao)</th>
                    <th>@Html.DisplayNameFor(model => model.ThoiGianCapNhat)</th>
                    <th>@Html.DisplayNameFor(model => model.MaPhongNavigation)</th>
                    <th>@Html.DisplayNameFor(model => model.MaSvNavigation)</th>
                    <th>@Html.DisplayNameFor(model => model.NguoiXuLyNavigation)</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>
                            @(ViewBag.SenderDisplay != null && ((System.Collections.Generic.Dictionary<string, string>)ViewBag.SenderDisplay).ContainsKey(item.MaPhanAnh) ? ((System.Collections.Generic.Dictionary<string, string>)ViewBag.SenderDisplay)[item.MaPhanAnh] : "")
                        </td>
                        <td>@item.MoTa</td>
                        <td>@item.MucDoUuTien</td>
                        <td>
                            @if(!string.IsNullOrEmpty(item.MediaPath))
                            {
                                var url = item.MediaPath;
                                if(item.MediaType == "image")
                                {
                                    <a asp-action="Details" asp-route-id="@item.MaPhanAnh"><img src="@url" style="max-width:120px; max-height:90px" /></a>
                                }
                                else if(item.MediaType == "video")
                                {
                                    <a asp-action="Details" asp-route-id="@item.MaPhanAnh"><video src="@url" controls style="max-width:160px; max-height:90px"></video></a>
                                }
                                else
                                {
                                    <a href="@url">Tệp đính kèm</a>
                                }
                            }
                        </td>
                        <td>
                            @{
                                var map = ViewBag.StatusMap as System.Collections.Generic.Dictionary<string,string>;
                                if(map != null && !string.IsNullOrEmpty(item.TrangThai) && map.ContainsKey(item.TrangThai))
                                {
                                    @map[item.TrangThai]
                                }
                                else
                                {
                                    @item.TrangThai
                                }
                            }
                        </td>
                        <td>@item.ThoiGianTao</td>
                        <td>@item.ThoiGianCapNhat</td>
                        <td>@item.MaPhongNavigation?.MaPhong</td>
                        <td>@(item.MaSvNavigation != null ? item.MaSvNavigation.HoTen : item.MaSv)</td>
                        <td>@item.NguoiXuLyNavigation?.MaTaiKhoan</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.MaPhanAnh" class="btn btn-info btn-sm me-1">Chi tiết</a>
                            @if(Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
                            {
                                <a asp-action="Edit" asp-route-id="@item.MaPhanAnh" class="btn btn-warning btn-sm me-1">Sửa</a>
                            }
                            @if (Context.Session.GetString("userRole") == "3")
                            {
                                <a asp-action="Delete" asp-route-id="@item.MaPhanAnh" class="btn btn-danger btn-sm">Xóa</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
