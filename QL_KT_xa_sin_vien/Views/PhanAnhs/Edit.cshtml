@model QL_KT_xa_sin_vien.Models.PhanAnh

@{
    ViewData["Title"] = "Chỉnh sửa phản ánh";
}

<h2 class="mb-4">Chỉnh sửa thông tin phản ánh</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <input type="hidden" asp-for="MaPhanAnh" />

            <div class="mb-3">
                <label asp-for="MaSv" class="form-label"></label>
                @* Do not allow selecting MaSv / sender in any case — always fixed from session *@
                <input type="hidden" asp-for="MaSv" value="@ViewBag.FixedMaSv" />
                <input class="form-control" value="@ViewBag.FixedHoTen" readonly />
                <span asp-validation-for="MaSv" class="text-danger"></span>
            </div>

            <div class="mb-3 form-check">
                <input type="checkbox" class="form-check-input" id="anDanh" name="AnDanh" value="true" @(Model.AnDanh==true?"checked":"") />
                <label class="form-check-label" for="anDanh">Ẩn danh (ẩn tên người gửi với sinh viên khác)</label>
            </div>

            <div class="mb-3">
                <label asp-for="MaPhong" class="form-label"></label>
                <select asp-for="MaPhong" class="form-select" asp-items="ViewBag.MaPhong"></select>
                <span asp-validation-for="MaPhong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MoTa" class="form-label">Mô tả <span class="text-danger">*</span></label>
                <textarea asp-for="MoTa" class="form-control" rows="3" required></textarea>
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MucDoUuTien" class="form-label"></label>
                <input asp-for="MucDoUuTien" class="form-control" />
                <span asp-validation-for="MucDoUuTien" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TrangThai" class="form-label"></label>
                <input asp-for="TrangThai" class="form-control" />
                <span asp-validation-for="TrangThai" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NguoiXuLy" class="form-label"></label>
                <select asp-for="NguoiXuLy" class="form-select" asp-items="ViewBag.NguoiXuLy"></select>
                <span asp-validation-for="NguoiXuLy" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ThoiGianTao" class="form-label"></label>
                <input asp-for="ThoiGianTao" class="form-control" />
                <span asp-validation-for="ThoiGianTao" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ThoiGianCapNhat" class="form-label"></label>
                <input asp-for="ThoiGianCapNhat" class="form-control" />
                <span asp-validation-for="ThoiGianCapNhat" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Đính kèm hiện tại</label>
                @if(!string.IsNullOrEmpty(Model.MediaPath))
                {
                    if(Model.MediaType == "image") { <div><img src="@Model.MediaPath" style="max-width:200px; max-height:150px" /></div> }
                    else if(Model.MediaType == "video") { <div><video src="@Model.MediaPath" controls style="max-width:320px; max-height:200px"></video></div> }
                    else { <div><a href="@Model.MediaPath">Tệp đính kèm</a></div> }
                    <div class="form-check mt-2">
                        <input class="form-check-input" type="checkbox" id="removeMedia" name="RemoveMedia" value="true" />
                        <label class="form-check-label" for="removeMedia">Xóa tệp đính kèm hiện tại</label>
                    </div>
                }
                else
                {
                    <div>(Chưa có tệp đính kèm)</div>
                }
            </div>

            <div class="mb-3">
                <label class="form-label">Thay thế / Thêm đính kèm (ảnh hoặc video ≤ 30s)</label>
                <input type="file" name="mediaFile" id="mediaFile" class="form-control" accept="image/*,video/*,text/plain" />
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary me-2">Lưu</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
