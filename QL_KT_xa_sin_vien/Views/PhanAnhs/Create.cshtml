@model QL_KT_xa_sin_vien.Models.PhanAnh

@{
    ViewData["Title"] = "Thêm phản ánh";
}

<h2 class="mb-4">Thêm phản ánh mới</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" asp-controller="PhanAnhs">
            <div asp-validation-summary="All" class="alert alert-danger"></div>
            <input type="hidden" asp-for="MaPhanAnh" />
            <input type="hidden" asp-for="MucDoUuTien" />
            <input type="hidden" asp-for="TrangThai" />

            <div class="mb-3">
                <label asp-for="MaSv" class="form-label"></label>
                <select asp-for="MaSv" class="form-select" asp-items="ViewBag.MaSv"></select>
                <span asp-validation-for="MaSv" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MaPhong" class="form-label"></label>
                <select asp-for="MaPhong" class="form-select" asp-items="ViewBag.MaPhong"></select>
                <span asp-validation-for="MaPhong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MoTa" class="form-label"></label>
                <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NguoiXuLy" class="form-label"></label>
                <select asp-for="NguoiXuLy" asp-items="@(ViewData["NguoiXuLy"] as SelectList)" class="form-select"></select>
                <span asp-validation-for="NguoiXuLy" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ThoiGianTao" class="form-label"></label>
                <input asp-for="ThoiGianTao" class="form-control" />
                <span asp-validation-for="ThoiGianTao" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ThoiGianCapNhat" class="form-label"></label>
                <input asp-for="ThoiGianCapNhat" class="form-control" />
                <span asp-validation-for="ThoiGianCapNhat" class="text-danger"></span>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary me-2">Tạo mới</button>
        [HttpGet]
        [Route("PhanAnhs/Create")]
        public IActionResult Create()
        {
            // Your logic here
        }

        [HttpPost]
        [Route("PhanAnhs/Create")]
        public IActionResult Create(PhanAnh model)
        {
            // Your logic here
        }

                <a asp-action="Index" asp-controller="PhanAnhs" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
