@model QL_KT_xa_sin_vien.Models.PhanAnh

@{
    ViewData["Title"] = "Chi tiết phản ánh";
}

<h2 class="mb-4">Chi tiết phản ánh</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <tr>
                <th>Mô tả</th>
                <td>@Model.MoTa</td>
            </tr>
            <tr>
                <th>Mức độ ưu tiên</th>
                <td>@Model.MucDoUuTien</td>
            </tr>
            <tr>
                <th>Trạng thái</th>
                <td>@Model.TrangThai</td>
            </tr>
            <tr>
                <th>Thời gian tạo</th>
                <td>@Model.ThoiGianTao</td>
            </tr>
            <tr>
                <th>Thời gian cập nhật</th>
                <td>@Model.ThoiGianCapNhat</td>
            </tr>
            <tr>
                <th>Phòng</th>
                <td>@Model.MaPhongNavigation?.MaPhong</td>
            </tr>
            <tr>
                <th>Sinh viên</th>
                <td>@(Model.MaSvNavigation != null ? Model.MaSvNavigation.HoTen : Model.MaSv)</td>
            </tr>
            <tr>
                <th>Người xử lý</th>
                <td>@Model.NguoiXuLyNavigation?.MaTaiKhoan</td>
            </tr>
            <tr>
                <th>Người gửi</th>
                <td>@(ViewBag.SenderDisplay ?? (Model.MaSvNavigation != null ? Model.MaSvNavigation.HoTen : Model.MaSv))</td>
            </tr>
            <tr>
                <th>Người gửi</th>
                <td>@(ViewBag.SenderDisplay ?? "")</td>
            </tr>
        </table>

        <div class="mt-3">
            @if(Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
            {
                <a asp-action="Edit" asp-route-id="@Model?.MaPhanAnh" class="btn btn-warning me-2">Chỉnh sửa</a>
            }
            <a asp-action="Index" asp-controller="PhanAnhs" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
