@model QL_KT_xa_sin_vien.Models.PhanAnh

@{
    ViewData["Title"] = "Xóa phản ánh";
}

<h2 class="mb-4 text-danger">Xóa phản ánh</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">Bạn có chắc chắn muốn xóa phản ánh này?</h5>
        <table class="table table-striped table-bordered">
            <tr>
                <th>Mô tả</th>
                <td>@Model.MoTa</td>
            </tr>
            <tr>
                <th>Mức độ ưu tiên</th>
                <td>@Model.MucDoUuTien</td>
            </tr>
            <tr>
                <th>Trạng thái</th>
                <td>@Model.TrangThai</td>
            </tr>
            <tr>
                <th>Thời gian tạo</th>
                <td>@Model.ThoiGianTao</td>
            </tr>
            <tr>
                <th>Thời gian cập nhật</th>
                <td>@Model.ThoiGianCapNhat</td>
            </tr>
            <tr>
                <th>Phòng</th>
                <td>@Model.MaPhongNavigation?.MaPhong</td>
            </tr>
            <tr>
                <th>Sinh viên</th>
                <td>@Model.MaSvNavigation?.MaSv</td>
            </tr>
            <tr>
                <th>Người xử lý</th>
                <td>@Model.NguoiXuLyNavigation?.MaTaiKhoan</td>
            </tr>
        </table>

        <div class="mt-3">
            <form asp-action="Delete" method="post" class="d-inline">
                <input type="hidden" asp-for="MaPhanAnh" />
                <button type="submit" class="btn btn-danger me-2">Xóa</button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
