@model QL_KT_xa_sin_vien.Models.Giuong

@{
    ViewData["Title"] = "Thêm giường";
}

<h2 class="mb-4">Thêm giường mới</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" asp-controller="Giuongs">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="MaGiuong" class="form-label"></label>
                <input asp-for="MaGiuong" class="form-control" />
                <span asp-validation-for="MaGiuong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MaPhong" class="form-label"></label>
                <select asp-for="MaPhong" class="form-select" asp-items="ViewBag.MaPhong"></select>
            </div>

            <div class="mb-3">
                <label asp-for="SoGiuong" class="form-label"></label>
                <input asp-for="SoGiuong" class="form-control" />
                <span asp-validation-for="SoGiuong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="OccupiedBy" class="form-label">Sinh viên đang sử dụng</label>
                <input asp-for="OccupiedBy" class="form-control" />
                <span asp-validation-for="OccupiedBy" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TrangThai" class="form-label"></label>
                <select asp-for="TrangThai" class="form-select">
                    <option value="Trống">Trống</option>
                    <option value="Đang sử dụng">Đang sử dụng</option>
                </select>
                <span asp-validation-for="TrangThai" class="text-danger"></span>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary me-2">Tạo mới</button>
                <a asp-action="Index" asp-controller="Giuongs" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
