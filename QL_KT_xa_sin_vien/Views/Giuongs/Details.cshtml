@model QL_KT_xa_sin_vien.Models.Giuong

@{
    ViewData["Title"] = "Chi tiết giường";
}

<h2 class="mb-4">Chi tiết giường</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <tr>
                <th>Số giường</th>
                <td>@Model.SoGiuong</td>
            </tr>
            <tr>
                <th>Trạng thái</th>
                <td>
                    @if (Model.TrangThai == "Đang sử dụng")
                    {
                        <span class="badge bg-danger">Đang sử dụng</span>
                    }
                    else if (Model.TrangThai == "Trống")
                    {
                        <span class="badge bg-success">Trống</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@Model.TrangThai</span>
                    }
                </td>
            </tr>
            <tr>
                <th>Phòng</th>
                <td>@Model.MaPhongNavigation?.MaPhong</td>
            </tr>
            <tr>
                <th>Sinh viên đang sử dụng</th>
                <td>@Model.OccupiedByNavigation?.MaSv</td>
            </tr>
        </table>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model?.MaGiuong" class="btn btn-warning me-2">Chỉnh sửa</a>
            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
