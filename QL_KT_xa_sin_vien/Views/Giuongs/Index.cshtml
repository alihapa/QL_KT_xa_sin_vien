@model IEnumerable<QL_KT_xa_sin_vien.Models.Giuong>

@{
    ViewData["Title"] = "Danh sách giường";
}

<h2 class="mb-4">Danh sách giường trong ký túc xá</h2>

<p>
    <a asp-action="Create" class="btn btn-success mb-3">+ Thêm giường mới</a>
</p>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.SoGiuong)</th>
                    <th>@Html.DisplayNameFor(model => model.TrangThai)</th>
                    <th>@Html.DisplayNameFor(model => model.MaPhongNavigation)</th>
                    <th>@Html.DisplayNameFor(model => model.OccupiedByNavigation)</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.SoGiuong</td>
                        <td>
                            @if (item.TrangThai == "Đang sử dụng")
                            {
                                <span class="badge bg-danger">Đang sử dụng</span>
                            }
                            else if (item.TrangThai == "Trống")
                            {
                                <span class="badge bg-success">Trống</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.TrangThai</span>
                            }
                        </td>
                        <td>@item.MaPhongNavigation?.MaPhong</td>
                        <td>@item.OccupiedByNavigation?.MaSv</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.MaGiuong" class="btn btn-warning btn-sm me-1">Sửa</a>
                            <a asp-action="Details" asp-route-id="@item.MaGiuong" class="btn btn-info btn-sm me-1">Chi tiết</a>
                            <a asp-action="Delete" asp-route-id="@item.MaGiuong" class="btn btn-danger btn-sm">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
