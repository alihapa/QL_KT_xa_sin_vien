@model IEnumerable<dynamic>

@{
    ViewBag.Title = "Kết quả tìm kiếm";
    var modelName = (ViewBag.model ?? Context.Request.Query["model"].ToString() ?? "").Trim();
    var searchString = (ViewBag.searchString ?? (Context.Request.Query.ContainsKey("searchString") ? Context.Request.Query["searchString"].ToString() : ""))?.ToString();
    var currentSort = (ViewBag.kieuSapXep ?? (Context.Request.Query.ContainsKey("sortOrder") ? Context.Request.Query["sortOrder"].ToString() : ""))?.ToString();

    int ParseQueryInt(string key, int defaultValue)
    {
        if (Context.Request.Query.ContainsKey(key) && int.TryParse(Context.Request.Query[key], out var v)) return v;
        return defaultValue;
    }

    var page = (int?)(ViewBag.page ?? ParseQueryInt("page", 1)) ?? 1;
    var totalPages = (int?)(ViewBag.totalPages ?? ParseQueryInt("totalPages", 1)) ?? 1;

    string SortIndicator(string col)
    {
        if (string.IsNullOrEmpty(currentSort)) return "";
        if (currentSort.StartsWith(col))
        {
            return currentSort.EndsWith("_desc") ? " ▼" : " ▲";
        }
        return "";
    }

    // Helper to format DateOnly/DateTime values safely when model is dynamic
    string FormatDate(object? val, string fmt = "dd/MM/yyyy")
    {
        if (val == null) return "";
        if (val is DateOnly d) return d.ToString(fmt);
        if (val is DateTime dt) return dt.ToString(fmt);
        // For nullable boxed values (e.g., DateOnly?) the runtime might present as boxed DateOnly
        try
        {
            return val.ToString() ?? "";
        }
        catch
        {
            return "";
        }
    }

    var sessionRole = Context.Session.GetString("userRole");
    string[] availableModels = ViewBag.availableModels as string[] ?? new string[0];
    var pageSize = (ViewBag.pageSize ?? (Context.Request.Query.ContainsKey("pageSize") ? Context.Request.Query["pageSize"].ToString() : "10"))?.ToString();

    string BuildRoute(string newSort = null, int? newPage = null)
    {
        var q = new Dictionary<string, string>();
        if (!string.IsNullOrEmpty(modelName)) q["model"] = modelName;
        if (!string.IsNullOrEmpty(searchString)) q["searchString"] = searchString;
        q["sortOrder"] = newSort ?? currentSort ?? "";
        q["page"] = (newPage ?? page).ToString();
        if (Context.Request.Query.ContainsKey("pageSize")) q["pageSize"] = Context.Request.Query["pageSize"].ToString();
        return Url.Action("TimKiem", "TimKiems", q);
    }
}

<h2>Kết quả tìm kiếm</h2>

<form method="get" asp-action="TimKiem" asp-controller="TimKiems" class="row g-2 mb-3">
    <div class="col-md-3">
        <label class="form-label">Model</label>
        <select name="model" class="form-select">
            <option value="">-- Chọn model --</option>
            @foreach (var m in availableModels)
            {
                if (m == modelName)
                {
                    <option value="@m" selected>@m</option>
                }
                else
                {
                    <option value="@m">@m</option>
                }
            }
        </select>
    </div>
    <div class="col-md-5">
        <label class="form-label">Từ khóa</label>
        <input type="text" name="searchString" class="form-control" placeholder="Nhập từ khóa..." value="@searchString" />
    </div>
    <div class="col-md-2">
        <label class="form-label">Số hàng</label>
        <select name="pageSize" class="form-select">
            @{ var sizes = new[] { "10", "25", "50", "100" }; }
            @foreach (var s in sizes)
            {
                if (s == pageSize)
                {
                    <option value="@s" selected>@s</option>
                }
                else
                {
                    <option value="@s">@s</option>
                }
            }
        </select>
    </div>
    <div class="col-md-2 d-grid">
        <label class="form-label">&nbsp;</label>
        <button type="submit" class="btn btn-primary">Tìm</button>
    </div>
</form>

@if (string.IsNullOrEmpty(modelName))
{
    <div>Vui lòng chọn model để tìm kiếm.</div>
}
else
{
    <div>
        <strong>Model:</strong> @modelName &nbsp; | &nbsp;
        <strong>Từ khóa:</strong> @(string.IsNullOrEmpty(searchString) ? "Không" : searchString) &nbsp; | &nbsp;
        <strong>Trang:</strong> @(page) / @totalPages
    </div>

    @switch (modelName)
    {
        case "SinhVien":
            {
                <table class="table table-striped table-bordered mt-2">
                    <thead>
                        <tr>
                            <th>
                                <a href='@BuildRoute(currentSort == "MaSv_desc" ? "MaSv_asc" : "MaSv_desc")'>Mã SV @(SortIndicator("MaSv"))</a>
                            </th>
                            <th>
                                <a href='@BuildRoute(currentSort == "HoTen_desc" ? "HoTen_asc" : "HoTen_desc")'>Họ tên @(SortIndicator("HoTen"))</a>
                            </th>
                            <th>Lớp</th>
                            <th>Email</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var s in Model)
                            {
                                <tr>
                                    <td>@s.MaSv</td>
                                    <td>@s.HoTen</td>
                                    <td>@s.Lop</td>
                                    <td>@s.Email</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4">Không có kết quả</td></tr>
                        }
                    </tbody>
                </table>
                break;
            }
        case "PhanAnh":
            {
                <table class="table table-striped table-bordered mt-2">
                    <thead>
                        <tr>
                            <th><a href='@BuildRoute(currentSort == "MaPhanAnh_desc" ? "MaPhanAnh_asc" : "MaPhanAnh_desc")'>Mã phản ánh @(SortIndicator("MaPhanAnh"))</a></th>
                            <th>Mã SV</th>
                            <th>Trạng thái</th>
                            <th>Thời gian</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var p in Model)
                            {
                                <tr>
                                    <td>@p.MaPhanAnh</td>
                                    <td>@p.MaSv</td>
                                    <td>@p.TrangThai</td>
                                <td>@FormatDate(p.ThoiGianTao, "dd/MM/yyyy HH:mm")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4">Không có kết quả</td></tr>
                        }
                    </tbody>
                </table>
                break;
            }
        case "HopDong":
            {
                <table class="table table-striped table-bordered mt-2">
                    <thead>
                        <tr>
                            <th>Mã hợp đồng</th>
                            <th>Mã SV</th>
                            <th>Ngày bắt đầu</th>
                            <th>Ngày kết thúc</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var h in Model)
                            {
                                <tr>
                                    <td>@h.MaHopDong</td>
                                    <td>@h.MaSv</td>
                                    <td>@FormatDate(h.NgayBatDau, "dd/MM/yyyy")</td>
                                    <td>@FormatDate(h.NgayKetThuc, "dd/MM/yyyy")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4">Không có kết quả</td></tr>
                        }
                    </tbody>
                </table>
                break;
            }
        case "HoaDon":
            {
                <table class="table table-striped table-bordered mt-2">
                    <thead>
                        <tr>
                            <th>Mã hóa đơn</th>
                            <th>Mã hợp đồng</th>
                            <th>Số tiền</th>
                            <th>Trạng thái</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var hd in Model)
                            {
                                <tr>
                                    <td>@hd.MaHoaDon</td>
                                    <td>@hd.MaHopDong</td>
                                    <td>@String.Format("{0:N0}", hd.SoTien)</td>
                                    <td>@hd.TrangThai</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4">Không có kết quả</td></tr>
                        }
                    </tbody>
                </table>
                break;
            }
        case "ThongBao":
            {
                <table class="table table-striped table-bordered mt-2">
                    <thead>
                        <tr>
                            <th>Mã thông báo</th>
                            <th>Người gửi</th>
                            <th>Người nhận</th>
                            <th>Nội dung</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var tb in Model)
                            {
                                <tr>
                                    <td>@tb.MaThongBao</td>
                                    <td>@tb.NguoiGui</td>
                                    <td>@tb.NguoiNhan</td>
                                    <td>@tb.NoiDung</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4">Không có kết quả</td></tr>
                        }
                    </tbody>
                </table>
                break;
            }
        case "TaiKhoan":
            {
                <table class="table table-striped table-bordered mt-2">
                    <thead>
                        <tr>
                            <th>Mã tài khoản</th>
                            <th>Tên đăng nhập</th>
                            <th>Email</th>
                            <th>Vai trò</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model != null && Model.Any())
                        {
                            foreach (var t in Model)
                            {
                                <tr>
                                    <td>@t.MaTaiKhoan</td>
                                    <td>@t.TenDangNhap</td>
                                    <td>@t.Email</td>
                                    <td>@t.VaiTro</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="4">Không có kết quả</td></tr>
                        }
                    </tbody>
                </table>
                break;
            }
        default:
            {
                <div>Model chưa được hỗ trợ trong view này.</div>
                break;
            }
    }

    <!-- Pagination -->
    <div class="mt-3">
        @if (totalPages > 1)
        {
            for (int i = 1; i <= totalPages; i++)
            {
                if (i == page)
                {
                    <strong>@i</strong>
                }
                else
                {
                    <a href="@BuildRoute(null, i)">@i</a>
                }
                <text> </text>
            }
        }
    </div>
}
