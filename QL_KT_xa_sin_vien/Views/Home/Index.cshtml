@using System.Text.Json

<meta charset="utf-8" />
@model QL_KT_xa_sin_vien.Models.DashboardViewModel
@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        @if (TempData["ErrorMessage"] != null)
        {
            <script>
                var msg = @Html.Raw(JsonSerializer.Serialize(TempData["ErrorMessage"]?.ToString()));
                Swal.fire({
                icon: 'error',
                title: 'Thông báo',
                text: msg,
                confirmButtonText: 'OK'
                });
            </script>
        }
    </script>
    <style>
        .car_ds {
        height: 100%;
        }

        .car_ds h3 {
        margin-bottom: 15px;
        color: #0066cc;
        }

        .car_ds p {
        margin: 5px 0;
        color: #444;
        }
    </style>
}
<link href="~/css/index.css" rel="stylesheet" />
<div class="dashboard-box">
    <h2>TỔNG QUAN HỆ THỐNG KÝ TÚC XÁ</h2>
    <div class="grid">
        <div class="card">
            <div class="car_ds">
                <h3>Thông tin cá nhân</h3>
                <p>Mã sinh viên: @Model.SinhVien.MaSv</p>
                <p>Họ tên: @Model.SinhVien.HoTen</p>
                <p>Lớp: @Model.SinhVien.Lop</p>
            </div>
            <a asp-controller="SinhViens" asp-action="Details" asp-route-id="@Model.SinhVien.MaSv" class="btn btn-primary">Chi tiết</a>
        </div>

        <div class="card">
            <div class="car_ds">
                <h3>Phòng đang ở</h3>
                <p>Tòa @Model.Phong.MaToaNha - Phòng @Model.Phong.MaPhong</p>
            </div>
            <a asp-action="Details" asp-controller="Phongs" asp-route-id="@Model.Phong.MaPhong" class="btn btn-primary">Xem chi tiết</a>
            @if (Model.Phong.MaPhong == "chưa có phòng")
            {
                <a asp-action="DangKy" asp-controller="Phongs" asp-route-id="@Model.SinhVien.MaSv" class="btn btn-success">Đăng ký phòng</a>
            }
        </div>

        <div class="card">
            <div class="car_ds">
                <h3>Hợp đồng</h3>
                <p>Bắt đầu: @Model.HopDong.NgayBatDau?.ToString("dd/MM/yyyy")</p>
                <p>Kết thúc: @Model.HopDong.NgayKetThuc?.ToString("dd/MM/yyyy")</p>
            </div>
            <a asp-controller="HopDongs" asp-action="Details" asp-route-id="@Model.HopDong.MaHopDong" class="btn btn-primary">Xem chi tiết</a>
        </div>

        <div class="card">
            <div class="car_ds">
                <h3>Hóa đơn</h3>
                @foreach (var hd in Model.HoaDons.Take(2))
                {
                    <table class="table">
                        <tr>
                            <th>Thời gian</th>
                            <th>Trạng thái</th>
                            <th></th>
                        </tr>
                        <tr>
                            <td>
                                Tháng @(hd.NgayXuat.HasValue? hd.NgayXuat.Value.Month : 0)/
                                @(hd.NgayXuat.HasValue? hd.NgayXuat.Value.Year : 0)
                            </td>
                            <td>@hd.TrangThai</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@hd.MaHoaDon" asp-controller="HoaDons" class="btn btn-info">Xem chi tiết</a>
                            </td>
                        </tr>
                    </table>
                }
            </div>
            <a asp-action="Index" asp-controller="HoaDons" class="btn btn-primary">Xem tất cả</a>
        </div>

        <div class="card">
            <div class="car_ds">
                <h3>Phản ánh sự cố</h3>
                @{
                    var phans = Model.PhanAnhs ?? new List<QL_KT_xa_sin_vien.Models.PhanAnh>();
                    int dangXacMinh = phans.Count(pa => !string.IsNullOrEmpty(pa.TrangThai) && pa.TrangThai.ToLowerInvariant().Contains("xác minh"));
                    int dangXuLy = phans.Count(pa => !string.IsNullOrEmpty(pa.TrangThai) && pa.TrangThai.ToLowerInvariant().Contains("xử lý") && !pa.TrangThai.ToLowerInvariant().Contains("xác minh"));
                    int hoanThanh = phans.Count(pa => !string.IsNullOrEmpty(pa.TrangThai) && pa.TrangThai.ToLowerInvariant().Contains("hoàn thành"));
                }
                <p>@dangXuLy phản ánh đang xử lý</p>
                <p>@dangXacMinh phản ánh đang xác minh</p>
                <p>@hoanThanh phản ánh đã hoàn thành</p>
            </div>
            @* <a asp-action="Create" asp-controller="PhanAnhs" class="btn btn-primary">Thêm phản ánh</a> *@
            <a asp-action="Index" asp-controller="PhanAnhs" class="btn btn-primary">Xem chi tiết</a>
        </div>

        <div class="card">
            <div class="car_ds">
                <h3>Thông báo</h3>
                @{ 
                    var allTbs = Model.ThongBaos ?? new List<QL_KT_xa_sin_vien.Models.ThongBao>();
                    var userIdTb = Context.Session.GetString("userId");
                    var personal = allTbs.Where(t => !string.IsNullOrEmpty(t.NguoiNhan) && t.NguoiNhan == userIdTb);
                    var common = allTbs.Where(t => string.IsNullOrEmpty(t.NguoiNhan));
                    var showList = personal.Concat(common).OrderByDescending(t => t.ThoiGianGui).Take(3).ToList();
                }
                @if (showList.Any())
                {
                    <ul class="list-unstyled mb-0">
                        @foreach (var tb in showList)
                        {
                            <li class="mb-2">
                                <strong>@tb.NoiDung</strong>
                                <div class="small text-muted">@tb.ThoiGianGui?.ToString("dd/MM/yyyy HH:mm")</div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <p class="text-muted">Không có thông báo</p>
                }
            </div>
            <a asp-action="Index" asp-controller="ThongBaos" class="btn btn-primary">Xem chi tiết</a>
        </div>
    </div>
</div>

