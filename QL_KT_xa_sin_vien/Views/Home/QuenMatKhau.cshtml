@using System.Text.Json
@model QL_KT_xa_sin_vien.Models.KichHoatRequestModel

@{
    ViewData["Title"] = "Quên mật khẩu";
}
@if (TempData["ErrorMessage"] != null)
{
    <script>
        var msg = @Html.Raw(JsonSerializer.Serialize(TempData["ErrorMessage"]?.ToString()));
        Swal.fire({
        icon: 'error',
        title: 'Thông báo',
        html: msg,
        confirmButtonText: 'OK'
        });
    </script>
}

<link href="~/css/quenmatkhau.css" rel="stylesheet" />

<div class="reset-box">
    <h2>QUÊN MẬT KHẨU</h2>
    <p class="text-center">Nhập email đã đăng ký để nhận hướng dẫn đặt lại mật khẩu</p>

    <form asp-action="QuenMatKhau" method="post">
        <div class="mb-3">
            <label for="email" class="form-label">Email:</label>
            <input type="email" id="email" name="Email" value="@(Model?.Email ?? "")" class="form-control" placeholder="vd: sv001@truong.edu.vn" required />
        </div>

        @if (Model?.Usernames != null && Model.Usernames.Any())
        {
            <div class="mb-3">
                <label for="selectedUsername" class="form-label">Tên đăng nhập (chọn để phân biệt)</label>
                <select id="selectedUsername" name="SelectedUsername" class="form-select" required>
                    <option value="">-- Chọn tài khoản --</option>
                    @foreach (var u in Model.Usernames)
                    {
                        <option value="@u">@u</option>
                    }
                </select>
            </div>
        }

        <div class="d-flex justify-content-between mt-3">
            <button type="submit" class="btn btn-warning">Gửi yêu cầu</button>
            <a asp-action="DangNhap" class="btn btn-primary">Quay lại đăng nhập</a>
        </div>
    </form>
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success mt-3">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="forgot mt-3 text-center">
        <a href="#">Tôi không nhận được email hướng dẫn</a>
    </div>
</div>
