@model QL_KT_xa_sin_vien.Models.KichHoatRequestModel

@{
    ViewData["Title"] = "Gửi mã kích hoạt";
}

<h2>Gửi mã kích hoạt</h2>

<div class="card">
    <div class="card-body">
        <form asp-action="KichHoatTaiKhoan" method="post">
            <div class="mb-3">
                <label for="email" class="form-label">Email đăng ký</label>
                <input id="email" name="Email" type="email" class="form-control" value="@(Model?.Email ?? "")" required />
            </div>
            @if (Model?.Usernames != null && Model.Usernames.Any())
            {
                <div class="mb-3">
                    <label for="selectedUsername" class="form-label">Tên đăng nhập (nhập để phân biệt)</label>
                    <input id="selectedUsername" name="SelectedUsername" type="text" class="form-control" placeholder="Nhập tên đăng nhập..." required />
                    <small class="form-text text-muted">Tài khoản khả dụng: @string.Join(", ", Model.Usernames)</small>
                </div>
            }
            <button type="submit" class="btn btn-primary">Gửi mã</button>
        </form>
    </div>
</div>
