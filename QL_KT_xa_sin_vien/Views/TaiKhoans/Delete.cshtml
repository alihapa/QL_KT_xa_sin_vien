@model QL_KT_xa_sin_vien.Models.TaiKhoan

@{
    ViewData["Title"] = "Xóa tài khoản";
}

<h2 class="mb-4 text-danger">Xóa tài khoản</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">Bạn có chắc chắn muốn xóa tài khoản này?</h5>
        <table class="table table-striped table-bordered">
            <tr>
                <th>Tên đăng nhập</th>
                <td>@Model.TenDangNhap</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>@Model.Email</td>
            </tr>
            <tr>
                <th>Số điện thoại</th>
                <td>@Model.Sdt</td>
            </tr>
            <tr>
                <th>Trạng thái</th>
                <td>
                    @if (Model.TrangThai == "Hoạt động")
                    {
                        <span class="badge bg-success">Hoạt động</span>
                    }
                    else if (Model.TrangThai == "Khóa")
                    {
                        <span class="badge bg-danger">Khóa</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@Model.TrangThai</span>
                    }
                </td>
            </tr>
            <tr>
                <th>Vai trò</th>
                <td>@Model.VaiTroNavigation?.MaVaiTro</td>
            </tr>
        </table>

        <div class="mt-3">
            <form asp-action="Delete" method="post" class="d-inline">
                <input type="hidden" asp-for="MaTaiKhoan" />
                <button type="submit" class="btn btn-danger me-2">Xóa</button>
            </form>
            <a asp-action="Index" asp-controller="TaiKhoans" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
