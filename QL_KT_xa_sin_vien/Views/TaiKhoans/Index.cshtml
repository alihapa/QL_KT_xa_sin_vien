@model IEnumerable<QL_KT_xa_sin_vien.Models.TaiKhoan>

@{
    ViewData["Title"] = "Danh sách tài khoản";
}

<h2 class="mb-4">Danh sách tài khoản</h2>

<p>
    <a asp-action="Create" class="btn btn-success mb-3">+ Thêm tài khoản mới</a>
    <a asp-action="BulkEdit" class="btn btn-outline-primary mb-3 ms-2">Chỉnh sửa hàng loạt (CSV)</a>
</p>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.TenDangNhap)</th>
                    <th>@Html.DisplayNameFor(model => model.Email)</th>
                    <th>@Html.DisplayNameFor(model => model.Sdt)</th>
                    <th>@Html.DisplayNameFor(model => model.TrangThai)</th>
                    <th>@Html.DisplayNameFor(model => model.VaiTroNavigation)</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TenDangNhap</td>
                        <td>@item.Email</td>
                        <td>@item.Sdt</td>
                        <td>
                            @if (item.TrangThai == "1")
                            {
                                <span class="badge bg-success">Hoạt động</span>
                            }
                            else if (item.TrangThai == "-1")
                            {
                                <span class="badge bg-danger">Bị cấm</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Chờ kích hoạt</span>
                            }
                        </td>
                        <td>@item.VaiTroNavigation?.MaVaiTro</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.MaTaiKhoan" class="btn btn-warning btn-sm me-1">Sửa</a>
                            <a asp-action="Details" asp-route-id="@item.MaTaiKhoan" class="btn btn-info btn-sm me-1">Chi tiết</a>
                            <a asp-action="Delete" asp-route-id="@item.MaTaiKhoan" class="btn btn-danger btn-sm">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
