@model QL_KT_xa_sin_vien.Models.TaiKhoan

@{
    ViewData["Title"] = "Thêm tài khoản";
}

<h2 class="mb-4">Thêm tài khoản mới</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <input asp-for="MaTaiKhoan" type="hidden" />

            <div class="mb-3">
                <label asp-for="TenDangNhap" class="form-label"></label>
                <input asp-for="TenDangNhap" class="form-control" />
                <span asp-validation-for="TenDangNhap" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MatKhauMh" class="form-label">Mật khẩu</label>
                <input asp-for="MatKhauMh" type="password" autocomplete="new-password" class="form-control" />
                <span asp-validation-for="MatKhauMh" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" type="email" class="form-control" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Sdt" class="form-label">Số điện thoại</label>
                <input asp-for="Sdt" type="tel" class="form-control" />
                <span asp-validation-for="Sdt" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="VaiTro" class="form-label">Vai trò</label>
                <select asp-for="VaiTro" class="form-select" asp-items="ViewBag.VaiTro"></select>
            </div>

            <div class="mb-3">
                <label asp-for="TrangThai" class="form-label"></label>
                <select asp-for="TrangThai" class="form-select">
                    <option value="1">Hoạt động</option>
                    <option value="0" selected>Chờ kích hoạt</option>
                </select>
                <span asp-validation-for="TrangThai" class="text-danger"></span>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary me-2">Tạo mới</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
