@model QL_KT_xa_sin_vien.Models.NhatKy

@{
    ViewData["Title"] = "Chỉnh sửa nhật ký";
}

<h2 class="mb-4">Chỉnh sửa thông tin nhật ký</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <input type="hidden" asp-for="MaLog" />

            <div class="mb-3">
                <label asp-for="NguoiThucHien" class="form-label"></label>
                <select asp-for="NguoiThucHien" class="form-select" asp-items="ViewBag.NguoiThucHien"></select>
                <span asp-validation-for="NguoiThucHien" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="HanhDong" class="form-label"></label>
                <input asp-for="HanhDong" class="form-control" />
                <span asp-validation-for="HanhDong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DoiTuong" class="form-label"></label>
                <input asp-for="DoiTuong" class="form-control" />
                <span asp-validation-for="DoiTuong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="GiaTriTruoc" class="form-label"></label>
                <input asp-for="GiaTriTruoc" class="form-control" />
                <span asp-validation-for="GiaTriTruoc" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="GiaTriSau" class="form-label"></label>
                <input asp-for="GiaTriSau" class="form-control" />
                <span asp-validation-for="GiaTriSau" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ThoiGian" class="form-label"></label>
                <input asp-for="ThoiGian" class="form-control" />
                <span asp-validation-for="ThoiGian" class="text-danger"></span>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary me-2">Lưu</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
