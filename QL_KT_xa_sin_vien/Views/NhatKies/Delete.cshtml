@model QL_KT_xa_sin_vien.Models.NhatKy

@{
    ViewData["Title"] = "Xóa nhật ký";
}

<h2 class="mb-4 text-danger">Xóa nhật ký</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">Bạn có chắc chắn muốn xóa nhật ký này?</h5>
        <table class="table table-striped table-bordered">
            <tr>
                <th>Hành động</th>
                <td>@Model.HanhDong</td>
            </tr>
            <tr>
                <th>Đối tượng</th>
                <td>@Model.DoiTuong</td>
            </tr>
            <tr>
                <th>Giá trị trước</th>
                <td>@Model.GiaTriTruoc</td>
            </tr>
            <tr>
                <th>Giá trị sau</th>
                <td>@Model.GiaTriSau</td>
            </tr>
            <tr>
                <th>Thời gian</th>
                <td>@Model.ThoiGian</td>
            </tr>
            <tr>
                <th>Người thực hiện</th>
                <td>@Model.NguoiThucHienNavigation?.MaTaiKhoan</td>
            </tr>
        </table>

        <div class="mt-3">
            <form asp-action="Delete" method="post" class="d-inline">
                <input type="hidden" asp-for="MaLog" />
                <button type="submit" class="btn btn-danger me-2">Xóa</button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
