@model QL_KT_xa_sin_vien.Models.NhatKy

@{
    ViewData["Title"] = "Chi tiết nhật ký";
}

<h2 class="mb-4">Chi tiết nhật ký</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <tr>
                <th>Hành động</th>
                <td>@Model.HanhDong</td>
            </tr>
            <tr>
                <th>Đối tượng</th>
                <td>@Model.DoiTuong</td>
            </tr>
            <tr>
                <th>Giá trị trước</th>
                <td>@Model.GiaTriTruoc</td>
            </tr>
            <tr>
                <th>Giá trị sau</th>
                <td>@Model.GiaTriSau</td>
            </tr>
            <tr>
                <th>Thời gian</th>
                <td>@Model.ThoiGian</td>
            </tr>
            <tr>
                <th>Người thực hiện</th>
                <td>@Model.NguoiThucHienNavigation?.MaTaiKhoan</td>
            </tr>
        </table>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model?.MaLog" class="btn btn-warning me-2">Chỉnh sửa</a>
            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
