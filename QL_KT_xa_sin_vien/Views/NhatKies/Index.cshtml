@model IEnumerable<QL_KT_xa_sin_vien.Models.NhatKy>

@{
    ViewData["Title"] = "Danh sách nhật ký";
}

<h2 class="mb-4">Danh sách nhật ký</h2>

<p>
    <a asp-action="Create" class="btn btn-success mb-3">+ Thêm nhật ký mới</a>
</p>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.HanhDong)</th>
                    <th>@Html.DisplayNameFor(model => model.DoiTuong)</th>
                    <th>@Html.DisplayNameFor(model => model.GiaTriTruoc)</th>
                    <th>@Html.DisplayNameFor(model => model.GiaTriSau)</th>
                    <th>@Html.DisplayNameFor(model => model.ThoiGian)</th>
                    <th>@Html.DisplayNameFor(model => model.NguoiThucHienNavigation)</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.HanhDong</td>
                        <td>@item.DoiTuong</td>
                        <td>@item.GiaTriTruoc</td>
                        <td>@item.GiaTriSau</td>
                        <td>@item.ThoiGian</td>
                        <td>@item.NguoiThucHienNavigation?.MaTaiKhoan</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.MaLog" class="btn btn-warning btn-sm me-1">Sửa</a>
                            <a asp-action="Details" asp-route-id="@item.MaLog" class="btn btn-info btn-sm me-1">Chi tiết</a>
                            <a asp-action="Delete" asp-route-id="@item.MaLog" class="btn btn-danger btn-sm">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
