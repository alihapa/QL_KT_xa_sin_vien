@model IEnumerable<QL_KT_xa_sin_vien.Models.NhatKy>

@{
    ViewData["Title"] = "Tìm kiếm nhật ký";
}

<h2 class="mb-4">Tìm kiếm nhật ký</h2>

<form method="get" class="row g-2 mb-3">
    <div class="col-md-3">
        <label class="form-label">Từ ngày</label>
        <input type="date" name="from" value="@ViewBag.from" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Đến ngày</label>
        <input type="date" name="to" value="@ViewBag.to" class="form-control" />
    </div>
    <div class="col-md-2 d-grid">
        <label class="form-label">&nbsp;</label>
        <button class="btn btn-primary">Lọc</button>
    </div>
    <div class="col-md-4 text-end">
        <label class="form-label">&nbsp;</label>
        <a asp-action="Export" class="btn btn-outline-secondary">Xuất nhật ký</a>
    </div>
</form>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Thời gian</th>
                    <th>Người thực hiện</th>
                    <th>Hành động</th>
                    <th>Đối tượng</th>
                    <th>Trước</th>
                    <th>Sau</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@(item.ThoiGian?.ToString("yyyy-MM-dd HH:mm:ss"))</td>
                        <td>@(item.NguoiThucHienNavigation?.TenDangNhap ?? item.NguoiThucHien)</td>
                        <td>@item.HanhDong</td>
                        <td>@item.DoiTuong</td>
                        <td>@item.GiaTriTruoc</td>
                        <td>@item.GiaTriSau</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="mt-3">
            @if (ViewBag.totalPages > 1)
            {
                for (int i = 1; i <= ViewBag.totalPages; i++)
                {
                    if (i == ViewBag.page)
                    {
                        <strong>@i</strong>
                    }
                    else
                    {
                        <a href="?from=@ViewBag.from&to=@ViewBag.to&page=@i">@i</a>
                    }
                    <text> </text>
                }
            }
        </div>
    </div>
</div>
