@model QL_KT_xa_sin_vien.Models.HopDong

@{
    ViewData["Title"] = "Chỉnh sửa hợp đồng";
}

<h2 class="mb-4">Chỉnh sửa thông tin hợp đồng</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <input type="hidden" asp-for="MaHopDong" />

            <div class="mb-3">
                <label asp-for="MaSv" class="form-label"></label>
                <select asp-for="MaSv" class="form-select" asp-items="ViewBag.MaSv"></select>
                <span asp-validation-for="MaSv" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MaPhong" class="form-label"></label>
                <select asp-for="MaPhong" class="form-select" asp-items="ViewBag.MaPhong"></select>
                <span asp-validation-for="MaPhong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MaGiuong" class="form-label"></label>
                <select asp-for="MaGiuong" class="form-select" asp-items="ViewBag.MaGiuong"></select>
                <span asp-validation-for="MaGiuong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NgayBatDau" class="form-label"></label>
                <input asp-for="NgayBatDau" type="date" class="form-control" />
                <span asp-validation-for="NgayBatDau" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NgayKetThuc" class="form-label"></label>
                <input asp-for="NgayKetThuc" type="date" class="form-control" />
                <span asp-validation-for="NgayKetThuc" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TrangThai" class="form-label"></label>
                <input asp-for="TrangThai" class="form-control" />
                <span asp-validation-for="TrangThai" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DieuKhoan" class="form-label"></label>
                <textarea asp-for="DieuKhoan" class="form-control" rows="3"></textarea>
                <span asp-validation-for="DieuKhoan" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label class="form-label">Đồng ý điều khoản</label>
                <select asp-for="Agree" class="form-select">
                    <option value="1" selected="@(Model.Agree=="1"?"selected":null)">Đồng ý</option>
                    <option value="2" selected="@(Model.Agree=="2"?"selected":null)">Không đồng ý</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Upload file điều khoản (PDF)</label>
                <input type="file" name="DieuKhoanPdfFile" accept="application/pdf" class="form-control" />
                @if(!string.IsNullOrEmpty(Model.DieuKhoanPdf))
                {
                    <a href="@Model.DieuKhoanPdf" target="_blank">Xem file hiện có</a>
                }
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary me-2">Lưu</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
