@model IEnumerable<QL_KT_xa_sin_vien.Models.HopDong>

@{
    ViewData["Title"] = "Danh sách hợp đồng";

    // Helper to safely format DateOnly/DateTime values
    string FormatDate(object? val, string fmt = "dd/MM/yyyy")
    {
        if (val == null) return "";
        if (val is DateOnly d) return d.ToString(fmt);
        if (val is DateTime dt) return dt.ToString(fmt);
        try { return val.ToString() ?? ""; } catch { return ""; }
    }
}

<h2 class="mb-4">Danh sách hợp đồng</h2>
@if (Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
{
    <p>
        <a asp-action="Create" class="btn btn-success mb-3">+ Thêm hợp đồng mới</a>
    </p>
}
<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.NgayBatDau)</th>
                    <th>@Html.DisplayNameFor(model => model.NgayKetThuc)</th>
                    <th>@Html.DisplayNameFor(model => model.TrangThai)</th>
                    <th>@Html.DisplayNameFor(model => model.DieuKhoan)</th>
                    <th>@Html.DisplayNameFor(model => model.MaGiuongNavigation)</th>
                    <th>@Html.DisplayNameFor(model => model.MaPhongNavigation)</th>
                    <th>@Html.DisplayNameFor(model => model.MaSvNavigation)</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@FormatDate(item.NgayBatDau, "dd/MM/yyyy")</td>
                        <td>@FormatDate(item.NgayKetThuc, "dd/MM/yyyy")</td>
                        <td>@item.TrangThai</td>
                        <td>@item.DieuKhoan</td>
                        <td>@item.MaGiuongNavigation?.MaGiuong</td>
                        <td>@item.MaPhongNavigation?.MaPhong</td>
                        <td>@item.MaSvNavigation?.MaSv</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.MaHopDong" class="btn btn-info btn-sm me-1">Chi tiết</a>
                            @if (Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
                            {
                                <a asp-action="Edit" asp-route-id="@item.MaHopDong" class="btn btn-warning btn-sm me-1">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.MaHopDong" class="btn btn-danger btn-sm">Xóa</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
