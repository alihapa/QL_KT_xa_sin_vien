@model IEnumerable<QL_KT_xa_sin_vien.Models.HopDong>

@{
    ViewData["Title"] = "Danh sách hợp đồng";

    // Helper to safely format DateOnly/DateTime values
    string FormatDate(object? val, string fmt = "dd/MM/yyyy")
    {
        if (val == null) return "";
        if (val is DateOnly d) return d.ToString(fmt);
        if (val is DateTime dt) return dt.ToString(fmt);
        try { return val.ToString() ?? ""; } catch { return ""; }
    }
}

<h2 class="mb-4">Danh sách hợp đồng</h2>
@if (Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
{
    <p>
        <a asp-action="Create" class="btn btn-success mb-3">+ Thêm hợp đồng mới</a>
    </p>
}
<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.NgayBatDau)</th>
                    <th>@Html.DisplayNameFor(model => model.NgayKetThuc)</th>
                    <th>Trạng thái</th>
                    <th>Điều khoản</th>
                    <th>PDF</th>
                    <th>Giường</th>
                    <th>Phòng</th>
                    <th>Sinh viên</th>
                    <th class="text-center">Thao tác</th>
                    @if (Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
                    {
                        <th></th>
                    }
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@FormatDate(item.NgayBatDau, "dd/MM/yyyy")</td>
                        <td>@FormatDate(item.NgayKetThuc, "dd/MM/yyyy")</td>
                        <td>
                            @{
                                var status = item.TrangThai ?? "";
                                string label = status switch
                                {
                                    "0" => "Chờ xét duyệt",
                                    "1" => "Đã duyệt",
                                    "2" => "Từ chối",
                                    "-1" => "Hết hạn",
                                    _ => status
                                };
                            }
                            @label
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.DieuKhoanPdf))
                            {
                                <a href="@item.DieuKhoanPdf" target="_blank">Xem điều khoản</a>
                            }
                            else if (!string.IsNullOrEmpty(ViewBag.LatestDieuKhoan as string))
                            {
                                <a href="@(ViewBag.LatestDieuKhoan)" target="_blank">Mở điều khoản</a>
                            }
                            else
                            {
                                <span class="text-muted">-</span>
                            }
                        </td>
                        <td>
                            @if(!string.IsNullOrEmpty(item.DieuKhoanPdf))
                            {
                                <a href="@item.DieuKhoanPdf" target="_blank">Xem PDF</a>
                            }
                        </td>
                        <td>@item.MaGiuongNavigation?.MaGiuong</td>
                        <td>@item.MaPhongNavigation?.MaPhong</td>
                        <td>@item.MaSvNavigation?.MaSv</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.MaHopDong" class="btn btn-info btn-sm me-1">Chi tiết</a>
                            @if (Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
                            {
                                <a asp-action="Edit" asp-route-id="@item.MaHopDong" class="btn btn-warning btn-sm me-1">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.MaHopDong" class="btn btn-danger btn-sm">Xóa</a>
                            }
                        </td>
                        @if(Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
                        {
                            <td>
                                <form asp-action="ChangeStatus" method="post" class="d-inline" onsubmit="return requireReason(this)">
                                    <input type="hidden" name="id" value="@item.MaHopDong" />
                                    <select name="newStatus" class="form-select d-inline w-auto">
                                        <option value="1">Đã xét duyệt</option>
                                        <option value="0">Chờ xét duyệt</option>
                                        <option value="-1">Hết hạn</option>
                                        <option value="2">Từ chối</option>
                                    </select>
                                    <input type="text" name="reason" placeholder="Lý do (nếu từ chối)" class="form-control d-inline w-50 ms-1" />
                                    <button type="submit" class="btn btn-success btn-sm ms-1">Cập nhật</button>
                                </form>
                            </td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<script>
    function requireReason(form) {
        var select = form.querySelector('select[name="newStatus"]');
        var reason = form.querySelector('input[name="reason"]');
        if (select && select.value === '2') {
            if (!reason || !reason.value.trim()) {
                alert('Vui lòng nhập lý do khi từ chối.');
                return false;
            }
        }
        return true;
    }
</script>
