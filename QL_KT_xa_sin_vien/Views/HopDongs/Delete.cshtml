@model QL_KT_xa_sin_vien.Models.HopDong

@{
    ViewData["Title"] = "Xóa hợp đồng";
}

<h2 class="mb-4 text-danger">Xóa hợp đồng</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">Bạn có chắc chắn muốn xóa hợp đồng này?</h5>
        <table class="table table-striped table-bordered">
            <tr>
                <th>Ngày bắt đầu</th>
                <td>@Model.NgayBatDau.Value.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr>
                <th>Ngày kết thúc</th>
                <td>@Model.NgayKetThuc.Value.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr>
                <th>Trạng thái</th>
                <td>-</td>
            </tr>
            <tr>
                <th>Điều khoản</th>
                <td>
                    @if(!string.IsNullOrEmpty(Model.DieuKhoanPdf))
                    {
                        <a href="@Model.DieuKhoanPdf" target="_blank">Xem file điều khoản đính kèm</a>
                    }
                    else
                    {
                        <span class="text-muted">Không có file điều khoản đính kèm. Tham khảo điều khoản chung.</span>
                    }
                </td>
            </tr>
            <tr>
                <th>Giường</th>
                <td>@Model.MaGiuongNavigation?.MaGiuong</td>
            </tr>
            <tr>
                <th>Phòng</th>
                <td>@Model.MaPhongNavigation?.MaPhong</td>
            </tr>
            <tr>
                <th>Sinh viên</th>
                <td>@Model.MaSvNavigation?.MaSv</td>
            </tr>
        </table>

        <div class="mt-3">
            <form asp-action="Delete" method="post" class="d-inline">
                <input type="hidden" asp-for="MaHopDong" />
                <button type="submit" class="btn btn-danger me-2">Xóa</button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>