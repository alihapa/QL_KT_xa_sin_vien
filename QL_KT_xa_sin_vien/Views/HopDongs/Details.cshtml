@model QL_KT_xa_sin_vien.Models.HopDong

@{
    ViewData["Title"] = "Chi tiết hợp đồng";
}

<h2 class="mb-4">Chi tiết hợp đồng</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <tr>
                <th>Ngày bắt đầu</th>
                <td>@Model.NgayBatDau.Value.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr>
                <th>Ngày kết thúc</th>
                <td>@Model.NgayKetThuc.Value.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr>
                <th>Trạng thái</th>
                <td>-</td>
            </tr>
            <tr>
                <th>Điều khoản</th>
                <td>
                    @if(!string.IsNullOrEmpty(Model.DieuKhoanPdf))
                    {
                        <div class="mt-2">
                            <embed src="@Model.DieuKhoanPdf" type="application/pdf" width="100%" height="600px" />
                            <div class="mt-2"><a href="@Model.DieuKhoanPdf" target="_blank" class="btn btn-link">Mở file trong tab mới</a></div>
                        </div>
                    }
                    else
                    {
                        <div class="text-muted">Hợp đồng không kèm file điều khoản. Vui lòng tham khảo điều khoản được quản lý tập trung.</div>
                    }
                </td>
            </tr>
            <div class="mb-3">
                <label class="form-label">Xem điều khoản</label>
                <div>
                    @if (!string.IsNullOrEmpty(ViewBag.LatestDieuKhoan as string))
                    {
                        <a class="btn btn-outline-primary" href="@ViewBag.LatestDieuKhoan" target="_blank">Mở điều khoản (@(ViewBag.LatestDieuKhoanName ?? "PDF"))</a>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có file điều khoản nào được tải lên.</span>
                    }
                </div>
                <span class="form-text">File điều khoản được quản lý tập trung; hợp đồng chỉ tham chiếu tới file này.</span>
            </div>
            <tr>
                <th>Giường</th>
                <td>@Model.MaGiuongNavigation?.MaGiuong</td>
            </tr>
            <tr>
                <th>Phòng</th>
                <td>@Model.MaPhongNavigation?.MaPhong</td>
            </tr>
            <tr>
                <th>Sinh viên</th>
                <td>@Model.MaSvNavigation?.MaSv</td>
            </tr>
        </table>

        <div class="mt-3">
            @if (Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
            { 
            <a asp-action="Edit" asp-route-id="@Model?.MaHopDong" class="btn btn-warning me-2">Chỉnh sửa</a>
            }
            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
