@model QL_KT_xa_sin_vien.Models.HopDong

@{
    ViewData["Title"] = "Chi tiết hợp đồng";
}

<h2 class="mb-4">Chi tiết hợp đồng</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <tr>
                <th>Ngày bắt đầu</th>
                <td>@Model.NgayBatDau.Value.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr>
                <th>Ngày kết thúc</th>
                <td>@Model.NgayKetThuc.Value.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr>
                <th>Trạng thái</th>
                <td>@Model.TrangThai</td>
            </tr>
            <tr>
                <th>Điều khoản</th>
                <td>@Model.DieuKhoan</td>
            </tr>
            <tr>
                <th>Giường</th>
                <td>@Model.MaGiuongNavigation?.MaGiuong</td>
            </tr>
            <tr>
                <th>Phòng</th>
                <td>@Model.MaPhongNavigation?.MaPhong</td>
            </tr>
            <tr>
                <th>Sinh viên</th>
                <td>@Model.MaSvNavigation?.MaSv</td>
            </tr>
        </table>

        <div class="mt-3">
            @if (Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
            { 
            <a asp-action="Edit" asp-route-id="@Model?.MaHopDong" class="btn btn-warning me-2">Chỉnh sửa</a>
            }
            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
