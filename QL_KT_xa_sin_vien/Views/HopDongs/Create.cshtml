@model QL_KT_xa_sin_vien.Models.HopDong

@{
    ViewData["Title"] = "Thêm hợp đồng";
}

<h2 class="mb-4">Thêm hợp đồng mới</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" asp-controller="HopDongs">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="MaHopDong" class="form-label"></label>
                <input asp-for="MaHopDong" class="form-control" />
                <span asp-validation-for="MaHopDong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MaSv" class="form-label"></label>
                <select asp-for="MaSv" class="form-select" asp-items="ViewBag.MaSv"></select>
            </div>

            <div class="mb-3">
                <label asp-for="MaPhong" class="form-label"></label>
                <select asp-for="MaPhong" class="form-select" asp-items="ViewBag.MaPhong"></select>
            </div>

            <div class="mb-3">
                <label asp-for="MaGiuong" class="form-label"></label>
                <select asp-for="MaGiuong" class="form-select" asp-items="ViewBag.MaGiuong"></select>
            </div>

            <div class="mb-3">
                <label asp-for="NgayBatDau" class="form-label"></label>
                <input asp-for="NgayBatDau" type="date" class="form-control" />
                <span asp-validation-for="NgayBatDau" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NgayKetThuc" class="form-label"></label>
                <input asp-for="NgayKetThuc" type="date" class="form-control" />
                <span asp-validation-for="NgayKetThuc" class="text-danger"></span>
            </div>

            @* Trạng thái và nội dung điều khoản được quản lý tập trung; không cho nhập trực tiếp trong form hợp đồng *@

            <div class="mb-3">
                <label class="form-label">Đồng ý điều khoản</label>
                <select asp-for="Agree" class="form-select">
                    <option value="1">Đồng ý</option>
                    <option value="2">Không đồng ý</option>
                </select>
            </div>

            <div class="mb-3">
                <label class="form-label">Xem điều khoản</label>
                <div>
                    @if (!string.IsNullOrEmpty(ViewBag.LatestDieuKhoan as string))
                    {
                        <a class="btn btn-outline-primary" href="@ViewBag.LatestDieuKhoan" target="_blank">Mở điều khoản (@(ViewBag.LatestDieuKhoanName ?? "PDF"))</a>
                    }
                    else
                    {
                        <span class="text-muted">Chưa có file điều khoản nào được tải lên.</span>
                    }
                </div>
                <span class="form-text">File điều khoản được quản lý tập trung; hợp đồng chỉ tham chiếu tới file này.</span>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary me-2">Tạo mới</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
