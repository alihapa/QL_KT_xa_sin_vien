@model QL_KT_xa_sin_vien.Models.SinhVien

@{
    ViewData["Title"] = "Chi tiết sinh viên";
}

<h2 class="mb-4">Thông tin chi tiết sinh viên</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <tr>
                <th>Họ tên</th>
                <td>@Model.HoTen</td>
            </tr>
            <tr>
                <th>Lớp</th>
                <td>@Model.Lop</td>
            </tr>
            <tr>
                <th>Giới tính</th>
                <td>@Model.GioiTinh</td>
            </tr>
            <tr>
                <th>Khoa</th>
                <td>@Model.Khoa</td>
            </tr>
            <tr>
                <th>Số CMND</th>
                <td>@Model.SoCmnd</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>@Model.Email</td>
            </tr>
        </table>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model?.MaSv" class="btn btn-warning me-2">Chỉnh sửa</a>
    @{
        var role = Context.Session.GetString("userRole");
        if (role == "2" || role == "3")
        {
            <a asp-action="Index" class="btn btn-info">Quay lại danh sách</a>
        }
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary ms-2">Quay lại</a>
</div>
