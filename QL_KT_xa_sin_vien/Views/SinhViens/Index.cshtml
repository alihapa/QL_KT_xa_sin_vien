@model IEnumerable<QL_KT_xa_sin_vien.Models.SinhVien>

@{
    ViewData["Title"] = "Danh sách sinh viên";
}

<h2 class="mb-4">Danh sách sinh viên</h2>
@if(Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
{
<p>
    <a asp-action="Create" class="btn btn-success mb-3">+ Thêm sinh viên mới</a>
    <a asp-action="BulkImport" class="btn btn-outline-primary mb-3 ms-2">Nhập hàng loạt (CSV)</a>
</p>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success">@TempData["SuccessMessage"]</div>
}

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.HoTen)</th>
                    <th>@Html.DisplayNameFor(model => model.Lop)</th>
                    <th>@Html.DisplayNameFor(model => model.Khoa)</th>
                    <th>@Html.DisplayNameFor(model => model.SoCmnd)</th>
                    <th>@Html.DisplayNameFor(model => model.Email)</th>
                    <th>@Html.DisplayNameFor(model => model.MaTaiKhoanNavigation)</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.HoTen</td>
                        <td>@item.Lop</td>
                        <td>@item.GioiTinh</td>
                        <td>@item.Khoa</td>
                        <td>@item.SoCmnd</td>
                        <td>@item.Email</td>
                        <td>@item.MaTaiKhoanNavigation?.MaTaiKhoan</td>
                        <td class="text-center">
                            @if(Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
                            {
                                <a asp-action="Edit" asp-route-id="@item.MaSv" class="btn btn-warning btn-sm me-1">Sửa</a>
                            }
                            <a asp-action="Details" asp-route-id="@item.MaSv" class="btn btn-info btn-sm me-1">Chi tiết</a>
                            @if(Context.Session.GetString("userRole") == "3")
                            {
                                <a asp-action="Delete" asp-route-id="@item.MaSv" class="btn btn-danger btn-sm">Xóa</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
