@model QL_KT_xa_sin_vien.Models.SinhVien

@{
    ViewData["Title"] = "Xóa sinh viên";
}

<h2 class="mb-4 text-danger">Xóa sinh viên</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">Bạn có chắc chắn muốn xóa sinh viên này?</h5>
        <table class="table table-striped table-bordered">
            <tr>
                <th>Họ tên</th>
                <td>@Model.HoTen</td>
            </tr>
            <tr>
                <th>Lớp</th>
                <td>@Model.Lop</td>
            </tr>
            <tr>
                <th>Khoa</th>
                <td>@Model.Khoa</td>
            </tr>
            <tr>
                <th>Số CMND</th>
                <td>@Model.SoCmnd</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>@Model.Email</td>
            </tr>
        </table>

        <div class="mt-3">
            <form asp-action="Delete" method="post" class="d-inline">
                <input type="hidden" asp-for="MaSv" />
                <button type="submit" class="btn btn-danger me-2">Xóa</button>
            </form>
            <a asp-action="Index" asp-controller="SinhViens" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
