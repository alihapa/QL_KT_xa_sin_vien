@{
    ViewData["Title"] = "Nhập sinh viên hàng loạt";
}

<h2 class="mb-4">Nhập sinh viên hàng loạt</h2>

<div class="card">
    <div class="card-body">
        <p>Tải lên file Excel (.xlsx) có cấu trúc cột: <strong>MaSv, HoTen, Lop, Khoa, Email</strong></p>
        <form asp-action="BulkImport" asp-controller="SinhViens" method="post" enctype="multipart/form-data">
            <div class="mb-3">
                <input type="file" name="file" accept=".xlsx" class="form-control" />
            </div>
            <div class="mb-3">
                <button type="submit" class="btn btn-primary">Tải lên và xử lý</button>
                <a asp-action="DownloadSample" class="btn btn-outline-secondary ms-2">Tải file mẫu</a>
                <a asp-action="Index" class="btn btn-secondary ms-2">Quay lại</a>
            </div>
        </form>
    </div>
</div>
