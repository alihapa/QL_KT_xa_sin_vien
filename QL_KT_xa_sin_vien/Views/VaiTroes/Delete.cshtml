@model QL_KT_xa_sin_vien.Models.VaiTro

@{
    ViewData["Title"] = "Xóa vai trò";
}

<h2 class="mb-4 text-danger">Xóa vai trò</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">Bạn có chắc chắn muốn xóa vai trò này?</h5>
        <table class="table table-striped table-bordered">
            <tr>
                <th>Tên vai trò</th>
                <td>@Model.TenVaiTro</td>
            </tr>
            <tr>
                <th>Quyền hạn</th>
                <td>@Model.QuyenHan</td>
            </tr>
        </table>

        <div class="mt-3">
            <form asp-action="Delete" method="post" class="d-inline">
                <input type="hidden" asp-for="MaVaiTro" />
                <button type="submit" class="btn btn-danger me-2">Xóa</button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
