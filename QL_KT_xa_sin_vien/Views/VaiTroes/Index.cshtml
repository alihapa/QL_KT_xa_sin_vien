@model IEnumerable<QL_KT_xa_sin_vien.Models.VaiTro>

@{
    ViewData["Title"] = "Danh sách vai trò";
}

<h2 class="mb-4">Danh sách vai trò</h2>

<p>
    <a asp-action="Create" class="btn btn-success mb-3">+ Thêm vai trò mới</a>
</p>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.TenVaiTro)</th>
                    <th>@Html.DisplayNameFor(model => model.QuyenHan)</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.TenVaiTro</td>
                        <td>@item.QuyenHan</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.MaVaiTro" class="btn btn-warning btn-sm me-1">Sửa</a>
                            <a asp-action="Details" asp-route-id="@item.MaVaiTro" class="btn btn-info btn-sm me-1">Chi tiết</a>
                            <a asp-action="Delete" asp-route-id="@item.MaVaiTro" class="btn btn-danger btn-sm">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
