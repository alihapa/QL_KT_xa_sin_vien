@model IEnumerable<QL_KT_xa_sin_vien.Models.TaiKhoan>

@{
    ViewData["Title"] = "Danh sách vai trò";
}

<h2 class="mb-4">Quản lý vai trò tài khoản</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Tài khoản</th>
                    <th>Tên đăng nhập</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var acc in Model)
                {
                    <tr>
                        <td>@acc.MaTaiKhoan</td>
                        <td>@acc.TenDangNhap</td>
                        <td>@acc.Email</td>
                    <td>@(acc.VaiTroNavigation?.TenVaiTro ?? acc.VaiTro)</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@acc.MaTaiKhoan" class="btn btn-info btn-sm me-1">Chi tiết</a>
                            <a asp-action="EditRole" asp-route-id="@acc.MaTaiKhoan" class="btn btn-warning btn-sm">Thay đổi vai trò</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
