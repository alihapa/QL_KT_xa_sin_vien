@model QL_KT_xa_sin_vien.Models.TaiKhoan

@{
    ViewData["Title"] = "Chỉnh vai trò";
}

<h2 class="mb-4">Chỉnh vai trò tài khoản</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="EditRole" method="post">
            <input type="hidden" asp-for="MaTaiKhoan" />

            <div class="mb-3">
                <label class="form-label">Tài khoản</label>
                <input class="form-control" value="@Model.MaTaiKhoan" readonly />
            </div>

            <div class="mb-3">
                <label class="form-label">Vai trò</label>
                <select name="VaiTro" class="form-select" asp-items="ViewBag.VaiTro"></select>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary">Lưu</button>
                <a asp-action="Index" class="btn btn-secondary">Hủy</a>
            </div>
        </form>
    </div>
</div>
