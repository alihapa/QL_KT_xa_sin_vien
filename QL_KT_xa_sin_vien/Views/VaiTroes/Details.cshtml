@model QL_KT_xa_sin_vien.Models.VaiTro

@{
    ViewData["Title"] = "Chi tiết vai trò";
}

<h2 class="mb-4">Chi tiết vai trò</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <tr>
                <th>Tên vai trò</th>
                <td>@Model.TenVaiTro</td>
            </tr>
            <tr>
                <th>Quyền hạn</th>
                <td>@Model.QuyenHan</td>
            </tr>
        </table>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model?.MaVaiTro" class="btn btn-warning me-2">Chỉnh sửa</a>
            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
