@model QL_KT_xa_sin_vien.Models.TaiKhoan

@{
    ViewData["Title"] = "Chi tiết tài khoản";
}

<h2 class="mb-4">Chi tiết tài khoản</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <tr>
                <th>Mã tài khoản</th>
                <td>@Model.MaTaiKhoan</td>
            </tr>
            <tr>
                <th>Tên đăng nhập</th>
                <td>@Model.TenDangNhap</td>
            </tr>
            <tr>
                <th>Email</th>
                <td>@Model.Email</td>
            </tr>
            <tr>
                <th>Vai trò</th>
                <td>@(Model.VaiTroNavigation?.TenVaiTro ?? Model.VaiTro)</td>
            </tr>
        </table>

        <div class="mt-3">
            <a asp-action="EditRole" asp-route-id="@Model.MaTaiKhoan" class="btn btn-warning me-2">Thay đổi vai trò</a>
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
        </div>
    </div>
</div>
