@using System.Text.Json
@model QL_KT_xa_sin_vien.Models.HoaDon

@{
    ViewData["Title"] = "Chi tiết hóa đơn";
}
@if (TempData["ErrorMessage"] != null)
{
    <script>
        var msg = @Html.Raw(JsonSerializer.Serialize(TempData["ErrorMessage"]?.ToString()));
        Swal.fire({
        icon: 'error',
        title: 'Thông báo',
        text: msg,
        confirmButtonText: 'OK'
        });
    </script>
}
@if (TempData["SuccessMessage"] != null)
{
    <script>
        var msg = @Html.Raw(JsonSerializer.Serialize(TempData["SuccessMessage"]?.ToString()));
        Swal.fire({
        icon: 'success',
        title: 'Thông báo',
        text: msg,
        confirmButtonText: 'OK'
        });
    </script>
}
<h2 class="mb-4">Chi tiết hóa đơn</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <tr>
                <th>Số tiền</th>
                <td>@String.Format("{0:N0} VNĐ", Model.SoTien)</td>
            </tr>
            <tr>
                <th>Trạng thái</th>
                <td>
                    @if (Model.TrangThai == "Đã thanh toán")
                    {
                        <span class="badge bg-success">Đã thanh toán</span>
                    }
                    else if (Model.TrangThai == "Chưa thanh toán")
                    {
                        <span class="badge bg-danger">Chưa thanh toán</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@Model.TrangThai</span>
                    }
                </td>
            </tr>
            <tr>
                <th>Ngày xuất</th>
                <td>@Model.NgayXuat?.ToString("dd/MM/yyyy")</td>
            </tr>
            <tr>
                <th>Mã hợp đồng</th>
                <td>@Model.MaHopDongNavigation?.MaHopDong</td>
            </tr>
            <tr>
                <th>Mã sinh viên</th>
                <td>@Model.MaSvNavigation?.MaSv</td>
            </tr>
        </table>

        <div class="mt-3">
            @if (Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
            {
                <a asp-action="Edit" asp-route-id="@Model?.MaHoaDon" class="btn btn-warning me-2">Chỉnh sửa</a>
            }
            <a asp-action="Index" asp-controller="HoaDons" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
