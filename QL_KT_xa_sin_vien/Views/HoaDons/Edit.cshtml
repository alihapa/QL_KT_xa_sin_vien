@model QL_KT_xa_sin_vien.Models.HoaDon

@{
    ViewData["Title"] = "Chỉnh sửa hóa đơn";
}

<h2 class="mb-4">Chỉnh sửa thông tin hóa đơn</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
            <input type="hidden" asp-for="MaHoaDon" />

            <div class="mb-3">
                <label asp-for="MaHopDong" class="form-label"></label>
                <select asp-for="MaHopDong" class="form-select" asp-items="ViewBag.MaHopDong"></select>
                <span asp-validation-for="MaHopDong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MaSv" class="form-label"></label>
                <select asp-for="MaSv" class="form-select" asp-items="ViewBag.MaSv"></select>
                <span asp-validation-for="MaSv" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SoTien" class="form-label"></label>
                <input asp-for="SoTien" type="number" class="form-control" />
                <span asp-validation-for="SoTien" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TrangThai" class="form-label"></label>
                <select asp-for="TrangThai" class="form-select">
                    <option value="Đã thanh toán">Đã thanh toán</option>
                    <option value="Chưa thanh toán">Chưa thanh toán</option>
                </select>
                <span asp-validation-for="TrangThai" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NgayXuat" class="form-label"></label>
                <input asp-for="NgayXuat" type="date" class="form-control" />
                <span asp-validation-for="NgayXuat" class="text-danger"></span>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary me-2">Lưu</button>
                <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
