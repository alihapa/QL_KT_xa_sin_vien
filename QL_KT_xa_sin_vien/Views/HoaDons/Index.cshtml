@model IEnumerable<QL_KT_xa_sin_vien.Models.HoaDon>

@{
    ViewData["Title"] = "Danh sách hóa đơn";
}

<h2 class="mb-4">Danh sách hóa đơn</h2>
@if (Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
{
    <p>
        <a asp-action="Create" class="btn btn-success mb-3">+ Thêm hóa đơn mới</a>
    </p>
}
<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.SoTien)</th>
                    <th>@Html.DisplayNameFor(model => model.TrangThai)</th>
                    <th>@Html.DisplayNameFor(model => model.NgayXuat)</th>
                    <th>@Html.DisplayNameFor(model => model.MaHopDongNavigation)</th>
                    <th>@Html.DisplayNameFor(model => model.MaSvNavigation)</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@String.Format("{0:N0} VNĐ", item.SoTien)</td>
                        <td>
                            @if (item.TrangThai == "Đã thanh toán")
                            {
                                <span class="badge bg-success">Đã thanh toán</span>
                            }
                            else if (item.TrangThai == "Chưa thanh toán")
                            {
                                <span class="badge bg-danger">Chưa thanh toán</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.TrangThai</span>
                            }
                        </td>
                        <td>@item.NgayXuat?.ToString("dd/MM/yyyy")</td>
                        <td>@item.MaHopDongNavigation?.MaHopDong</td>
                        <td>@item.MaSvNavigation?.MaSv</td>
                        <td class="text-center">
                            <a asp-action="Details" asp-route-id="@item.MaHoaDon" class="btn btn-info btn-sm me-1">Chi tiết</a>
                            @if (Context.Session.GetString("userRole") == "2" || Context.Session.GetString("userRole") == "3")
                            {
                                <a asp-action="Edit" asp-route-id="@item.MaHoaDon" class="btn btn-warning btn-sm me-1">Sửa</a>
                                <a asp-action="Delete" asp-route-id="@item.MaHoaDon" class="btn btn-danger btn-sm">Xóa</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
