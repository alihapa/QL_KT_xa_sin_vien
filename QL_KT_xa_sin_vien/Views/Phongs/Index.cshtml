@model IEnumerable<QL_KT_xa_sin_vien.Models.Phong>

@{
    ViewData["Title"] = "Danh sách phòng";
}

<h2 class="mb-4">Danh sách phòng</h2>
@if(Context.Session.GetString("userRole") == "3")
{
<p>
    <a asp-action="Create" class="btn btn-success mb-3">+ Thêm phòng mới</a>
</p>
}

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.Tang)</th>
                    <th>@Html.DisplayNameFor(model => model.LoaiPhong)</th>
                    <th>@Html.DisplayNameFor(model => model.SucChua)</th>
                    <th>@Html.DisplayNameFor(model => model.SoLuongDangO)</th>
                    <th>@Html.DisplayNameFor(model => model.GioiTinh)</th>
                    <th>@Html.DisplayNameFor(model => model.TrangThai)</th>
                    <th>@Html.DisplayNameFor(model => model.MaToaNhaNavigation)</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Tang</td>
                        <td>@item.LoaiPhong</td>
                        <td>@item.SucChua</td>
                        <td>@item.SoLuongDangO</td>
                        <td>@item.GioiTinh</td>
                        <td>@item.TrangThai</td>
                        <td>@item.MaToaNhaNavigation?.MaToaNha</td>
                        <td class="text-center">
                            @if(Context.Session.GetString("userRole") == "3")
                            {
                                <a asp-action="Edit" asp-route-id="@item.MaPhong" class="btn btn-warning btn-sm me-1">Sửa</a>
                                <a asp-action="Details" asp-route-id="@item.MaPhong" class="btn btn-info btn-sm me-1">Chi tiết</a>
                                <a asp-action="Delete" asp-route-id="@item.MaPhong" class="btn btn-danger btn-sm">Xóa</a>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
