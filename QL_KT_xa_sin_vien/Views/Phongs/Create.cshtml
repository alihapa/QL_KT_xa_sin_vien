@model QL_KT_xa_sin_vien.Models.Phong

@{
    ViewData["Title"] = "Thêm phòng";
}

<h2 class="mb-4">Thêm phòng mới</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" asp-controller="Phongs">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="MaPhong" class="form-label"></label>
                <input asp-for="MaPhong" class="form-control" />
                <span asp-validation-for="MaPhong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MaToaNha" class="form-label"></label>
                <select asp-for="MaToaNha" class="form-select" asp-items="ViewBag.ToaNha"></select>
            </div>

            <div class="mb-3">
                <label asp-for="Tang" class="form-label"></label>
                <input asp-for="Tang" class="form-control" />
                <span asp-validation-for="Tang" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="LoaiPhong" class="form-label"></label>
                <input asp-for="LoaiPhong" class="form-control" />
                <span asp-validation-for="LoaiPhong" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SucChua" class="form-label"></label>
                <input asp-for="SucChua" class="form-control" />
                <span asp-validation-for="SucChua" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="SoLuongDangO" class="form-label"></label>
                <input asp-for="SoLuongDangO" class="form-control" />
                <span asp-validation-for="SoLuongDangO" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="GioiTinh" class="form-label"></label>
                <input asp-for="GioiTinh" class="form-control" />
                <span asp-validation-for="GioiTinh" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TrangThai" class="form-label"></label>
                <input asp-for="TrangThai" class="form-control" />
                <span asp-validation-for="TrangThai" class="text-danger"></span>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary me-2">Tạo mới</button>
                <a asp-action="Index" asp-controller="Phongs" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
