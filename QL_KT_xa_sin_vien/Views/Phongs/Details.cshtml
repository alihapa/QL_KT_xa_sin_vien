@using System.Text.Json
@model QL_KT_xa_sin_vien.Models.Phong

@{
    ViewData["Title"] = "Chi tiết phòng";
}
@if (TempData["ErrorMessage"] != null)
{
    <script>
        var msg = @Html.Raw(JsonSerializer.Serialize(TempData["ErrorMessage"]?.ToString()));
        Swal.fire({
        icon: 'error',
        title: 'Thông báo',
        text: msg,
        confirmButtonText: 'OK'
        });
    </script>
}
@if (TempData["SuccessMessage"] != null)
{
    <script>
        var msg = @Html.Raw(JsonSerializer.Serialize(TempData["SuccessMessage"]?.ToString()));
        Swal.fire({
        icon: 'success',
        title: 'Thông báo',
        text: msg,
        confirmButtonText: 'OK'
        });
    </script>
}

<h2 class="mb-4">Thông tin chi tiết phòng</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-bordered">
            <tr>
                <th>Tầng</th>
                <td>@Model.Tang</td>
            </tr>
            <tr>
                <th>Loại phòng</th>
                <td>@Model.LoaiPhong</td>
            </tr>
            <tr>
                <th>Sức chứa</th>
                <td>@Model.SucChua</td>
            </tr>
            <tr>
                <th>Số lượng đang ở</th>
                <td>@Model.SoLuongDangO</td>
            </tr>
            <tr>
                <th>Giới tính</th>
                <td>@Model.GioiTinh</td>
            </tr>
            <tr>
                <th>Trạng thái</th>
                <td>@Model.TrangThai</td>
            </tr>
            <tr>
                <th>Tòa nhà</th>
                <td>@Model.MaToaNhaNavigation?.MaToaNha</td>
            </tr>
        </table>
    </div>
</div>

<div class="mt-3">
    @{
        var role = Context.Session.GetString("userRole");
        if (role == "2" || role == "3")
        {
            <a asp-action="Edit" asp-route-id="@Model?.MaPhong" class="btn btn-warning me-2">Sửa</a>
        }
    }
    <a asp-controller="Home" asp-action="Index" class="btn btn-secondary me-2">Trở lại trang chủ</a>
    <a asp-action="Index" class="btn btn-info">Xem danh sách phòng</a>
</div>
