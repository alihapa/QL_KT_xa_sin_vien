@model QL_KT_xa_sin_vien.Models.Phong

@{
    ViewData["Title"] = "Xóa phòng";
}

<h2 class="mb-4 text-danger">Xóa phòng</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">Bạn có chắc chắn muốn xóa phòng này?</h5>
        <table class="table table-striped table-bordered">
            <tr>
                <th>Tầng</th>
                <td>@Model.Tang</td>
            </tr>
            <tr>
                <th>Loại phòng</th>
                <td>@Model.LoaiPhong</td>
            </tr>
            <tr>
                <th>Sức chứa</th>
                <td>@Model.SucChua</td>
            </tr>
            <tr>
                <th>Số lượng đang ở</th>
                <td>@Model.SoLuongDangO</td>
            </tr>
            <tr>
                <th>Giới tính</th>
                <td>@Model.GioiTinh</td>
            </tr>
            <tr>
                <th>Trạng thái</th>
                <td>@Model.TrangThai</td>
            </tr>
            <tr>
                <th>Tòa nhà</th>
                <td>@Model.MaToaNhaNavigation?.MaToaNha</td>
            </tr>
        </table>

        <div class="mt-3">
            <form asp-action="Delete" asp-controller="Phongs" method="post" class="d-inline">
                <input type="hidden" asp-for="MaPhong" />
                <button type="submit" class="btn btn-danger me-2">Xóa</button>
            </form>
            <a asp-action="Index" asp-controller="Phongs" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
