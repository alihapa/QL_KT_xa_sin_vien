@model IEnumerable<QL_KT_xa_sin_vien.Models.ThongBao>

@{
    ViewData["Title"] = "Danh sách thông báo";
}

<h2 class="mb-4">Danh sách thông báo</h2>

<p>
    <a asp-action="Create" class="btn btn-success mb-3">+ Thêm thông báo mới</a>
</p>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>@Html.DisplayNameFor(model => model.LoaiThongBao)</th>
                    <th>@Html.DisplayNameFor(model => model.NoiDung)</th>
                    <th>@Html.DisplayNameFor(model => model.TrangThai)</th>
                    <th>@Html.DisplayNameFor(model => model.ThoiGianGui)</th>
                    <th>@Html.DisplayNameFor(model => model.NguoiNhanNavigation)</th>
                    <th class="text-center">Thao tác</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.LoaiThongBao</td>
                        <td>@item.NoiDung</td>
                        <td>
                            @if (item.TrangThai == "Đã gửi")
                            {
                                <span class="badge bg-success">Đã gửi</span>
                            }
                            else if (item.TrangThai == "Chưa gửi")
                            {
                                <span class="badge bg-warning text-dark">Chưa gửi</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">@item.TrangThai</span>
                            }
                        </td>
                        <td>@item.ThoiGianGui</td>
                        <td>@item.NguoiNhanNavigation?.MaTaiKhoan</td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.MaThongBao" class="btn btn-warning btn-sm me-1">Sửa</a>
                            <a asp-action="Details" asp-route-id="@item.MaThongBao" class="btn btn-info btn-sm me-1">Chi tiết</a>
                            <a asp-action="Delete" asp-route-id="@item.MaThongBao" class="btn btn-danger btn-sm">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
