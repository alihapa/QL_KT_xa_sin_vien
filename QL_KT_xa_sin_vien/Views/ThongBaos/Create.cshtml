@model QL_KT_xa_sin_vien.Models.ThongBao

@{
    ViewData["Title"] = "Thêm thông báo";
}

<h2 class="mb-4">Thêm thông báo mới</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" asp-controller="ThongBaos">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="MaThongBao" class="form-label"></label>
                <input asp-for="MaThongBao" class="form-control" />
                <span asp-validation-for="MaThongBao" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="NguoiGui" class="form-label"></label>
                <input asp-for="NguoiGui" value="@Context.Session.GetString("userId")" class="form-control" readonly />
            </div>

            <div class="mb-3">
                <label asp-for="LoaiThongBao" class="form-label">Loại thông báo</label>
                <select asp-for="LoaiThongBao" class="form-select" id="LoaiThongBao">
                    <option value="Chung">Chung</option>
                    <option value="Khẩn">Khẩn</option>
                    <option value="Cá nhân">Cá nhân</option>
                </select>
                <span asp-validation-for="LoaiThongBao" class="text-danger"></span>
            </div>

            <div class="mb-3" id="nguoiNhanGroup">
                <label asp-for="NguoiNhan" class="form-label">Người nhận</label>
                <select asp-for="NguoiNhan" class="form-select" asp-items="ViewBag.NguoiNhan"></select>
            </div>

            <div class="mb-3">
                <label asp-for="NoiDung" class="form-label"></label>
                <textarea asp-for="NoiDung" class="form-control" rows="4"></textarea>
                <span asp-validation-for="NoiDung" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TrangThai" class="form-label"></label>
                <select asp-for="TrangThai" class="form-select">
                    <option value="Đã gửi">Đã gửi</option>
                    <option value="Chưa gửi">Chưa gửi</option>
                </select>
                <span asp-validation-for="TrangThai" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="ThoiGianGui" class="form-label">Thời gian gửi</label>
                <input asp-for="ThoiGianGui" type="datetime-local" class="form-control" />
                <span asp-validation-for="ThoiGianGui" class="text-danger"></span>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary me-2">Tạo mới</button>
                <a asp-action="Index" asp-controller="ThongBaos" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            var loai = document.getElementById('LoaiThongBao');
            var nguoiGroup = document.getElementById('nguoiNhanGroup');
            function update() {
                if (!loai) return;
                if (loai.value === 'Chung') {
                    nguoiGroup.style.display = 'none';
                } else {
                    nguoiGroup.style.display = '';
                }
            }
            loai.addEventListener('change', update);
            update();
        });
    </script>
}
