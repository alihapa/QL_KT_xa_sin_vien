@model QL_KT_xa_sin_vien.Models.ThongBao

@{
    ViewData["Title"] = "Xóa thông báo";
}

<h2 class="mb-4 text-danger">Xóa thông báo</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">Bạn có chắc chắn muốn xóa thông báo này?</h5>
        <table class="table table-striped table-bordered">
            <tr>
                <th>Loại thông báo</th>
                <td>@Model.LoaiThongBao</td>
            </tr>
            <tr>
                <th>Nội dung</th>
                <td>@Model.NoiDung</td>
            </tr>
            <tr>
                <th>Trạng thái</th>
                <td>
                    @if (Model.TrangThai == "Đã gửi")
                    {
                        <span class="badge bg-success">Đã gửi</span>
                    }
                    else if (Model.TrangThai == "Chưa gửi")
                    {
                        <span class="badge bg-warning text-dark">Chưa gửi</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">@Model.TrangThai</span>
                    }
                </td>
            </tr>
            <tr>
                <th>Thời gian gửi</th>
                <td>@Model.ThoiGianGui</td>
            </tr>
            <tr>
                <th>Người nhận</th>
                <td>@Model.NguoiNhanNavigation?.MaTaiKhoan</td>
            </tr>
        </table>

        <div class="mt-3">
            <form asp-action="Delete" method="post" class="d-inline">
                <input type="hidden" asp-for="MaThongBao" />
                <button type="submit" class="btn btn-danger me-2">Xóa</button>
            </form>
            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
