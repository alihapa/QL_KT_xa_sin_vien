@model QL_KT_xa_sin_vien.Models.ToaNha

@{
    ViewData["Title"] = "Xóa tòa nhà";
}

<h2 class="mb-4 text-danger">Xóa tòa nhà</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <h5 class="mb-3">Bạn có chắc chắn muốn xóa tòa nhà này?</h5>
        <table class="table table-striped table-bordered">
            <tr>
                <th>Tên tòa nhà</th>
                <td>@Model.TenToaNha</td>
            </tr>
            <tr>
                <th>Địa chỉ</th>
                <td>@Model.DiaChi</td>
            </tr>
        </table>

        <div class="mt-3">
            <form asp-action="Delete" asp-controller="ToaNhas" method="post" class="d-inline">
                <input type="hidden" asp-for="MaToaNha" />
                <button type="submit" class="btn btn-danger me-2">Xóa</button>
            </form>
            <a asp-action="Index" asp-controller="ToaNhas" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
