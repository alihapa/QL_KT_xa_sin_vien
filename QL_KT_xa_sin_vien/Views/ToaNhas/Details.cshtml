@model QL_KT_xa_sin_vien.Models.ToaNha

@{
    ViewData["Title"] = "Chi tiết tòa nhà";
}

<h2 class="mb-4">Chi tiết tòa nhà</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <table class="table table-striped table-bordered">
            <tr>
                <th>Tên tòa nhà</th>
                <td>@Model.TenToaNha</td>
            </tr>
            <tr>
                <th>Địa chỉ</th>
                <td>@Model.DiaChi</td>
            </tr>
        </table>

        <div class="mt-3">
            <a asp-action="Edit" asp-route-id="@Model?.MaToaNha" class="btn btn-warning me-2">Chỉnh sửa</a>
            <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
        </div>
    </div>
</div>
