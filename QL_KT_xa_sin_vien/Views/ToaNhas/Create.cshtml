@model QL_KT_xa_sin_vien.Models.ToaNha

@{
    ViewData["Title"] = "Thêm tòa nhà";
}

<h2 class="mb-4">Thêm tòa nhà mới</h2>

<div class="card shadow-sm">
    <div class="card-body">
        <form asp-action="Create" asp-controller="ToaNhas">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="mb-3">
                <label asp-for="MaToaNha" class="form-label"></label>
                <input asp-for="MaToaNha" class="form-control" />
                <span asp-validation-for="MaToaNha" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="TenToaNha" class="form-label"></label>
                <input asp-for="TenToaNha" class="form-control" />
                <span asp-validation-for="TenToaNha" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="DiaChi" class="form-label"></label>
                <input asp-for="DiaChi" class="form-control" />
                <span asp-validation-for="DiaChi" class="text-danger"></span>
            </div>

            <div class="mt-3">
                <button type="submit" class="btn btn-primary me-2">Tạo mới</button>
                <a asp-action="Index" asp-controller="ToaNhas" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
